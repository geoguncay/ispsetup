# ============================================================
# ISP Platform — Variables de entorno (copiar a .env)
# ============================================================

# --- App ---
ENVIRONMENT=development          # development | production
DEBUG=true
APP_NAME="ISP Platform"

# --- Base de datos ---
POSTGRES_USER=isp_user
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=isp_platform
DATABASE_URL=postgresql://isp_user:changeme_strong_password@postgres:5432/isp_platform

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Seguridad JWT ---
# Generar con: openssl rand -hex 32
SECRET_KEY=generate_with_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Cifrado Fernet (credenciales de routers) ---
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=generate_with_fernet_generate_key

# --- Integraciones NMS / MikroTik ---
# IP alcanzable desde los Gateways MikroTik (Traffic Flow, Accounting y Radius)
NMS_SERVER_IP=10.0.0.10
TRAFFIC_FLOW_PORT=2055
# Secreto compartido para los modos PPP/Hotspot Radius
RADIUS_SECRET=generate_a_strong_shared_secret

# --- Usuario admin inicial (seed) ---
ADMIN_SEED_EMAIL=admin@isp.local
ADMIN_SEED_PASSWORD=admin_password
ADMIN_SEED_NAME=Administrador
# Clave para el endpoint POST /api/auth/setup (forma 2 de crear el admin)
# Usa una clave larga y aleatoria en producción: openssl rand -hex 24
ADMIN_SEED_KEY=generate_with_openssl_rand_hex_24

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80

# --- Twilio (Fase 4 — notificaciones) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_PHONE=

# --- SMTP (Fase 4 — email) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# --- SRI Ecuador (Fase 4 — facturación) ---
# SRI_RUC=
# SRI_AMBIENTE=pruebas    # pruebas | produccion
# SRI_CERT_PATH=/certs/firma.p12
# SRI_CERT_PASSWORD=
